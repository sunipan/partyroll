        "photos_image_derivatives_required": {
          "name": "photos_image_derivatives_required",
          "value": "(\"photos\".\"media_kind\" <> 'image') or (\"photos\".\"display_object_key\" is not null and \"photos\".\"thumbnail_object_key\" is not null and (\"photos\".\"status\" <> 'ready' or (\"photos\".\"width\" is not null and \"photos\".\"height\" is not null)))"
        },
        "photos_video_original_only": {
          "name": "photos_video_original_only",
          "value": "(\"photos\".\"media_kind\" <> 'video') or (\"photos\".\"display_object_key\" is null and \"photos\".\"thumbnail_object_key\" is null and \"photos\".\"width\" is null and \"photos\".\"height\" is null)"
        },
        "photos_original_object_key_not_blank": {
