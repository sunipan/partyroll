          "value": "length(btrim(\"photos\".\"declared_mime_type\")) > 0"
        },
        "photos_display_object_key_not_blank": {
          "name": "photos_display_object_key_not_blank",
          "value": "\"photos\".\"display_object_key\" is null or length(btrim(\"photos\".\"display_object_key\")) > 0"
        },
        "photos_thumbnail_object_key_not_blank": {
          "name": "photos_thumbnail_object_key_not_blank",
          "value": "\"photos\".\"thumbnail_object_key\" is null or length(btrim(\"photos\".\"thumbnail_object_key\")) > 0"
        },
        "photos_quarantine_object_key_not_blank": {
          "name": "photos_quarantine_object_key_not_blank",
          "value": "length(btrim(\"photos\".\"quarantine_object_key\")) > 0"
        },
        "photos_declared_media_kind_matches_mime": {
          "name": "photos_declared_media_kind_matches_mime",
          "value": "((\"photos\".\"media_kind\" = 'image' and \"photos\".\"declared_mime_type\" in ('image/jpeg', 'image/png', 'image/webp', 'image/heic', 'image/heif')) or (\"photos\".\"media_kind\" = 'video' and \"photos\".\"declared_mime_type\" in ('video/mp4', 'video/quicktime', 'video/webm')))"
        },
        "photos_ready_final_metadata_required": {
          "name": "photos_ready_final_metadata_required",
          "value": "(\"photos\".\"status\" <> 'ready') or (\"photos\".\"ready_at\" is not null and \"photos\".\"mime_type\" is not null and \"photos\".\"byte_size\" is not null)"
        },
        "photos_non_ready_final_metadata_absent": {
          "name": "photos_non_ready_final_metadata_absent",
          "value": "(\"photos\".\"status\" = 'ready') or (\"photos\".\"ready_at\" is null and \"photos\".\"mime_type\" is null and \"photos\".\"byte_size\" is null and \"photos\".\"width\" is null and \"photos\".\"height\" is null)"
        },
        "photos_final_mime_type_matches_media_kind": {
          "name": "photos_final_mime_type_matches_media_kind",
          "value": "\"photos\".\"mime_type\" is null or ((\"photos\".\"media_kind\" = 'image' and \"photos\".\"mime_type\" in ('image/jpeg', 'image/png', 'image/webp', 'image/heic', 'image/heif')) or (\"photos\".\"media_kind\" = 'video' and \"photos\".\"mime_type\" in ('video/mp4', 'video/quicktime', 'video/webm')))"
        },
